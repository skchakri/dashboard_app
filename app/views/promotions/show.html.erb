<div class="max-w-4xl mx-auto">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center space-x-3 mb-3">
      <%= link_to dashboard_path, class: "text-blue-600 hover:text-blue-800" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Create Promotion</h1>
    </div>
    <p class="text-gray-600 dark:text-gray-400">Generate engaging social media content for your product</p>
  </div>

  <!-- Product Info -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-6 p-6">
    <div class="flex items-start space-x-4">
      <% if @product.product_images.any? %>
        <img src="<%= @product.product_images.first.image_url %>" 
             alt="<%= @product.product_images.first.alt_text %>"
             class="w-20 h-20 rounded-lg object-cover">
      <% else %>
        <div class="w-20 h-20 bg-gray-200 dark:bg-gray-700 rounded-lg flex items-center justify-center">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      <% end %>
      
      <div class="flex-1">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white">
          <%= @product.display_name(@user_market) %>
        </h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">SKU: <%= @product.sku %></p>
        <p class="text-sm text-gray-600 dark:text-gray-300 mt-2 line-clamp-2">
          <%= @product.display_description(@user_market) %>
        </p>
        <div class="flex items-center space-x-4 mt-3">
          <span class="text-lg font-semibold text-gray-900 dark:text-white">
            <%= @user_market&.currency || '$' %><%= number_with_precision(@product.display_price(@user_market), precision: 2) %>
          </span>
          <% if @user_market %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              <%= @user_market.name %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Content Generation Form -->
  <%= form_with url: promote_product_path(@product), method: :post, local: true, 
      data: { controller: "promotion-form" }, 
      class: "space-y-6" do |form| %>
    
    <!-- Audience Type Selection -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Target Audience</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @audience_types.each do |audience| %>
          <label class="relative border border-gray-200 dark:border-gray-700 rounded-lg p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500 has-[:checked]:ring-2 has-[:checked]:ring-blue-200">
            <%= form.radio_button :audience_type, audience[:id], class: "absolute top-2 left-2 w-4 h-4 text-blue-600 focus:ring-blue-500", required: true %>
            <div class="flex items-start space-x-3 ml-6">
              <div class="flex-1">
                <h4 class="text-sm font-medium text-gray-900 dark:text-white"><%= audience[:name] %></h4>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= audience[:description] %></p>
              </div>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <!-- Message Tone Selection -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Message Tone</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @message_tones.each do |tone| %>
          <label class="relative border border-gray-200 dark:border-gray-700 rounded-lg p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500 has-[:checked]:ring-2 has-[:checked]:ring-blue-200">
            <%= form.radio_button :message_tone, tone[:id], class: "absolute top-2 left-2 w-4 h-4 text-blue-600 focus:ring-blue-500", required: true %>
            <div class="flex items-start space-x-3 ml-6">
              <div class="flex-1">
                <h4 class="text-sm font-medium text-gray-900 dark:text-white"><%= tone[:name] %></h4>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= tone[:description] %></p>
              </div>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <!-- Social Platform Selection -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Social Platform</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <label class="relative border border-gray-200 dark:border-gray-700 rounded-lg p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500 has-[:checked]:ring-2 has-[:checked]:ring-blue-200">
          <%= form.radio_button :social_platform, 'facebook', class: "absolute top-2 right-2 w-4 h-4 text-blue-600 focus:ring-blue-500", checked: true %>
          <div class="text-center">
            <div class="w-8 h-8 mx-auto mb-2 text-blue-600">
              <svg fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Facebook</span>
          </div>
        </label>
        
        <label class="relative border border-gray-200 dark:border-gray-700 rounded-lg p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors has-[:checked]:bg-pink-50 has-[:checked]:border-pink-500 has-[:checked]:ring-2 has-[:checked]:ring-pink-200">
          <%= form.radio_button :social_platform, 'instagram', class: "absolute top-2 right-2 w-4 h-4 text-pink-600 focus:ring-pink-500" %>
          <div class="text-center">
            <div class="w-8 h-8 mx-auto mb-2 text-pink-600">
              <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Instagram</span>
          </div>
        </label>
        
        <label class="relative border border-gray-200 dark:border-gray-700 rounded-lg p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors has-[:checked]:bg-sky-50 has-[:checked]:border-sky-500 has-[:checked]:ring-2 has-[:checked]:ring-sky-200">
          <%= form.radio_button :social_platform, 'twitter', class: "absolute top-2 right-2 w-4 h-4 text-sky-600 focus:ring-sky-500" %>
          <div class="text-center">
            <div class="w-8 h-8 mx-auto mb-2 text-sky-500">
              <svg fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Twitter</span>
          </div>
        </label>
        
        <label class="relative border border-gray-200 dark:border-gray-700 rounded-lg p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors has-[:checked]:bg-blue-50 has-[:checked]:border-blue-700 has-[:checked]:ring-2 has-[:checked]:ring-blue-200">
          <%= form.radio_button :social_platform, 'linkedin', class: "absolute top-2 right-2 w-4 h-4 text-blue-700 focus:ring-blue-500" %>
          <div class="text-center">
            <div class="w-8 h-8 mx-auto mb-2 text-blue-700">
              <svg fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">LinkedIn</span>
          </div>
        </label>
      </div>
    </div>

    <!-- Context Selection -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6" 
         data-controller="context-selector"
         data-context-selector-prompts-value="<%= @context_prompts.to_json %>">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Content Context</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Choose a context type to help generate more targeted content</p>
      
      <!-- Context Type Dropdown -->
      <div class="mb-4">
        <%= form.select :context_prompt, 
            options_for_select(@context_prompts.map { |p| [p[:name], p[:id]] }, ''), 
            { prompt: 'Select context type...' },
            { 
              class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white",
              data: { 
                context_selector_target: "select",
                action: "change->context-selector#selectChanged"
              }
            } %>
      </div>

      <!-- Context Prompt Descriptions -->
      <div class="mb-4">
        <% @context_prompts.each do |prompt| %>
          <div class="context-description hidden p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-md" 
               data-context-id="<%= prompt[:id] %>">
            <h4 class="text-sm font-medium text-blue-900 dark:text-blue-100"><%= prompt[:name] %></h4>
            <p class="text-xs text-blue-700 dark:text-blue-300 mt-1"><%= prompt[:prompt] %></p>
          </div>
        <% end %>
      </div>

      <!-- Custom Message Field -->
      <div data-context-selector-target="customField">
        <%= form.text_area :custom_message, 
            placeholder: "Any specific message, promotion details, or context you'd like to include...",
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white",
            rows: 3 %>
      </div>
    </div>

    <!-- Generate Button -->
    <div class="flex justify-end">
      <%= form.submit "Generate Content", 
          class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors",
          data: { disable_with: "Generating..." } %>
    </div>
  <% end %>
</div>
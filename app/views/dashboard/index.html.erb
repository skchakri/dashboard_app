<div class="mb-4">
  <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">
    Welcome back, <%= current_user.display_name %>!
  </h1>
  <p class="text-gray-600 dark:text-gray-400">Here's what's happening with your account today.</p>
</div>

<!-- Stats Cards Row -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <!-- Stat Card 1 -->
  <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">Total Projects</dt>
            <dd class="text-lg font-medium text-gray-900 dark:text-white">8</dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Stat Card 2 -->
  <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">Completed Tasks</dt>
            <dd class="text-lg font-medium text-gray-900 dark:text-white">24</dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Stat Card 3 -->
  <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">This Month</dt>
            <dd class="text-lg font-medium text-gray-900 dark:text-white">+12%</dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Stat Card 4 -->
  <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
    <div class="p-5">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
          </svg>
        </div>
        <div class="ml-5 w-0 flex-1">
          <dl>
            <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">Revenue</dt>
            <dd class="text-lg font-medium text-gray-900 dark:text-white">$12,428</dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Content - 2 Column Layout -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Left Column - Main Content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Recent Activity Widget -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Recent Activity</h3>
        <div class="flow-root">
          <ul class="-mb-8">
            <li class="relative pb-8">
              <div class="relative flex space-x-3">
                <div>
                  <span class="h-8 w-8 rounded-full bg-green-500 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </span>
                </div>
                <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                  <div>
                    <p class="text-sm text-gray-900 dark:text-white">
                      Completed project setup and initial configuration
                    </p>
                  </div>
                  <div class="text-right text-sm whitespace-nowrap text-gray-500">
                    2h ago
                  </div>
                </div>
              </div>
            </li>
            
            <li class="relative pb-8">
              <div class="relative flex space-x-3">
                <div>
                  <span class="h-8 w-8 rounded-full bg-blue-500 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6z" />
                    </svg>
                  </span>
                </div>
                <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                  <div>
                    <p class="text-sm text-gray-900 dark:text-white">
                      Updated profile information
                    </p>
                  </div>
                  <div class="text-right text-sm whitespace-nowrap text-gray-500">
                    1d ago
                  </div>
                </div>
              </div>
            </li>

            <li class="relative">
              <div class="relative flex space-x-3">
                <div>
                  <span class="h-8 w-8 rounded-full bg-gray-400 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" />
                    </svg>
                  </span>
                </div>
                <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                  <div>
                    <p class="text-sm text-gray-900 dark:text-white">
                      System backup completed
                    </p>
                  </div>
                  <div class="text-right text-sm whitespace-nowrap text-gray-500">
                    2d ago
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Products for Your Market -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">
            Products for <%= @user_market&.name || 'Your Market' %>
          </h3>
          <% if @user_market %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
              <%= @user_market.currency %>
            </span>
          <% end %>
        </div>
        
        <% if @products.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% @products.each do |product| %>
              <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow">
                <div class="flex justify-between items-start mb-3">
                  <div class="flex-1">
                    <h4 class="text-sm font-medium text-gray-900 dark:text-white">
                      <%= product.display_name(@user_market) %>
                    </h4>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                      SKU: <%= product.sku %>
                    </p>
                  </div>
                  <% if product.product_images.any? %>
                    <img src="<%= product.product_images.first.image_url %>" 
                         alt="<%= product.product_images.first.alt_text %>"
                         class="w-12 h-12 rounded-md object-cover ml-3">
                  <% end %>
                </div>
                
                <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 line-clamp-2">
                  <%= truncate(product.display_description(@user_market), length: 100) %>
                </p>
                
                <div class="flex justify-between items-center">
                  <div class="flex flex-col">
                    <span class="text-lg font-semibold text-gray-900 dark:text-white">
                      <%= @user_market&.currency || '$' %><%= number_with_precision(product.display_price(@user_market), precision: 2) %>
                    </span>
                    <% if product.categories.any? %>
                      <div class="flex flex-wrap gap-1 mt-1">
                        <% product.categories.limit(2).each do |category| %>
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                            <%= category.name %>
                          </span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                  <%= link_to promote_product_path(product), 
                      class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do %>
                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                    Promote
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M34 40h10v-4a6 6 0 00-10.712-3.714M34 40H14m20 0v-4a9.971 9.971 0 00-.712-3.714M14 40H4v-4a6 6 0 0110.713-3.714M14 40v-4c0-1.313.253-2.566.713-3.714m0 0A9.971 9.971 0 0118 32c4.418 0 7.971 2.718 9.287 6.286M30 20a6 6 0 11-12 0 6 6 0 0112 0zm6 40v-2a4 4 0 00-4-4H16a4 4 0 00-4 4v2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No products available</h3>
            <p class="mt-1 text-sm text-gray-500">No products are currently available for your market.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Right Column - Sidebar -->
  <div class="space-y-6">
    <!-- Progress Widget -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">This Week's Progress</h3>
        <div class="space-y-3">
          <div>
            <div class="flex justify-between text-sm font-medium text-gray-700 dark:text-gray-300">
              <span>Tasks Completed</span>
              <span>75%</span>
            </div>
            <div class="mt-1 bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 75%"></div>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between text-sm font-medium text-gray-700 dark:text-gray-300">
              <span>Goals Achieved</span>
              <span>60%</span>
            </div>
            <div class="mt-1 bg-gray-200 rounded-full h-2">
              <div class="bg-green-600 h-2 rounded-full" style="width: 60%"></div>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between text-sm font-medium text-gray-700 dark:text-gray-300">
              <span>Time Spent</span>
              <span>85%</span>
            </div>
            <div class="mt-1 bg-gray-200 rounded-full h-2">
              <div class="bg-yellow-600 h-2 rounded-full" style="width: 85%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Notifications -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Recent Notifications</h3>
        <div class="space-y-3">
          <div class="flex space-x-3">
            <div class="flex-shrink-0">
              <div class="h-2 w-2 bg-blue-400 rounded-full mt-2"></div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm text-gray-900 dark:text-white">New message from team lead</p>
              <p class="text-xs text-gray-500">5 min ago</p>
            </div>
          </div>
          
          <div class="flex space-x-3">
            <div class="flex-shrink-0">
              <div class="h-2 w-2 bg-green-400 rounded-full mt-2"></div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm text-gray-900 dark:text-white">Project approved</p>
              <p class="text-xs text-gray-500">1 hour ago</p>
            </div>
          </div>
          
          <div class="flex space-x-3">
            <div class="flex-shrink-0">
              <div class="h-2 w-2 bg-yellow-400 rounded-full mt-2"></div>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm text-gray-900 dark:text-white">Deadline reminder</p>
              <p class="text-xs text-gray-500">2 hours ago</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">Account Overview</h3>
        <dl class="space-y-3">
          <div class="flex justify-between">
            <dt class="text-sm font-medium text-gray-500">Member since</dt>
            <dd class="text-sm text-gray-900 dark:text-white">Jan 2024</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm font-medium text-gray-500">Plan</dt>
            <dd class="text-sm text-gray-900 dark:text-white">Professional</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-sm font-medium text-gray-500">Storage used</dt>
            <dd class="text-sm text-gray-900 dark:text-white">2.1 GB / 10 GB</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>

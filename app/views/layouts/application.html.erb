<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dashboard App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- TailwindCSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Flowbite CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.2.1/flowbite.min.css" rel="stylesheet" />
    
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Custom CSS variables for themes -->
    <style>
      :root {
        --primary-color: #3b82f6;
        --secondary-color: #64748b;
        --success-color: #22c55e;
        --warning-color: #f59e0b;
        --error-color: #ef4444;
        --bg-color: #f8fafc;
        --surface-color: #ffffff;
        --text-color: #1e293b;
      }

      [data-theme="admin"] {
        --primary-color: #1e40af;
        --secondary-color: #475569;
        --bg-color: #f1f5f9;
        --surface-color: #ffffff;
        --text-color: #0f172a;
      }

      [data-theme="user"] {
        --primary-color: #3b82f6;
        --secondary-color: #64748b;
        --bg-color: #f8fafc;
        --surface-color: #ffffff;
        --text-color: #1e293b;
      }
    </style>
  </head>

  <body class="<%= authenticated? ? (current_user_admin? ? 'admin-theme' : 'user-theme') : '' %>" 
        data-theme="<%= authenticated? ? (current_user_admin? ? 'admin' : 'user') : 'default' %>">
    <div id="flash_messages">
      <%= render 'shared/flash' if notice || alert %>
    </div>
    <%= yield %>

    <!-- Flowbite JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.2.1/flowbite.min.js"></script>
  </body>
</html>

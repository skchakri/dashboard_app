<div class="space-y-6">
  <!-- Header -->
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <nav class="flex" aria-label="Breadcrumb">
        <ol role="list" class="flex items-center space-x-4">
          <li>
            <div>
              <%= link_to admin_cost_reports_path(company_id: @target_company&.id), 
                  class: "text-gray-400 hover:text-gray-500" do %>
                <span class="sr-only">Cost Reports</span>
                <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M2 3.75A.75.75 0 012.75 3h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 3.75zM2 7.5a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 7.5zM2 11.25a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zM2 15a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 15z" clip-rule="evenodd" />
                </svg>
              <% end %>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="h-5 w-5 flex-shrink-0 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="m5.555 17.776 4-16 .894.448-4 16-.894-.448z" />
              </svg>
              <%= link_to "Cost Reports", admin_cost_reports_path(company_id: @target_company&.id), 
                  class: "ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" %>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="h-5 w-5 flex-shrink-0 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="m5.555 17.776 4-16 .894.448-4 16-.894-.448z" />
              </svg>
              <span class="ml-4 text-sm font-medium text-gray-500"><%= @user.email %></span>
            </div>
          </li>
        </ol>
      </nav>
      <h2 class="mt-2 text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
        <%= @user.email %> - Usage Details
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        Detailed AI usage logs for <%= @target_company.name %>
      </p>
    </div>
    <div class="mt-4 flex md:ml-4 md:mt-0">
      <!-- Date Range Selector -->
      <div class="mr-4">
        <%= form_with url: admin_cost_reports_user_path(@user, company_id: @target_company&.id), method: :get, local: true, class: "flex items-center space-x-2" do |form| %>
          <%= form.select :date_range,
              options_for_select([
                ['Last 7 days', '7_days'],
                ['Last 30 days', '30_days'],
                ['Last 90 days', '90_days'],
                ['Current month', 'current_month'],
                ['Last month', 'last_month']
              ], @date_range),
              {},
              { 
                class: "block w-36 rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6",
                onchange: "this.form.submit();"
              } %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- User Summary Cards -->
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6">
      <dt class="truncate text-sm font-medium text-gray-500">Total Cost</dt>
      <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">
        $<%= sprintf("%.2f", @user_totals[:total_cost]) %>
      </dd>
    </div>
    
    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6">
      <dt class="truncate text-sm font-medium text-gray-500">Total Requests</dt>
      <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">
        <%= number_with_delimiter(@user_totals[:total_requests]) %>
      </dd>
      <dd class="mt-1 text-sm text-gray-500">
        <%= @user_totals[:text_requests] %> text, <%= @user_totals[:image_requests] %> images
      </dd>
    </div>
    
    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6">
      <dt class="truncate text-sm font-medium text-gray-500">Input Tokens</dt>
      <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">
        <%= number_with_delimiter(@user_totals[:total_input_tokens]) %>
      </dd>
    </div>
    
    <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6">
      <dt class="truncate text-sm font-medium text-gray-500">Output Tokens</dt>
      <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900">
        <%= number_with_delimiter(@user_totals[:total_output_tokens]) %>
      </dd>
    </div>
  </div>

  <!-- Usage Logs Table -->
  <div class="overflow-hidden rounded-lg bg-white shadow">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-base font-semibold leading-6 text-gray-900">Usage Logs</h3>
      <p class="mt-2 text-sm text-gray-700">Detailed log of all AI requests made by this user</p>
      
      <div class="mt-6 flow-root">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
          <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
            <table class="min-w-full divide-y divide-gray-300">
              <thead>
                <tr>
                  <th class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-0">Date</th>
                  <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Type</th>
                  <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Model</th>
                  <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Platform</th>
                  <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Tokens</th>
                  <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Cost</th>
                  <th class="relative py-3.5 pl-3 pr-4 sm:pr-0">
                    <span class="sr-only">View</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <% @usage_logs.each do |log| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm sm:pl-0">
                      <div class="font-medium text-gray-900">
                        <%= log.created_at.strftime("%m/%d/%y") %>
                      </div>
                      <div class="text-gray-500 text-xs">
                        <%= log.created_at.strftime("%I:%M %p") %>
                      </div>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm">
                      <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium <%= log.model_type == 'text' ? 'bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-700/10' : 'bg-green-50 text-green-700 ring-1 ring-inset ring-green-600/20' %>">
                        <%= log.model_type.capitalize %>
                      </span>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-900">
                      <%= log.ai_model %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                      <% if log.platform.present? %>
                        <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">
                          <%= log.platform.capitalize %>
                        </span>
                      <% else %>
                        <span class="text-gray-400">-</span>
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                      <% if log.model_type == 'text' %>
                        <div class="text-xs">
                          <span class="text-gray-900"><%= number_with_delimiter(log.input_tokens) %></span> in
                        </div>
                        <div class="text-xs">
                          <span class="text-gray-900"><%= number_with_delimiter(log.output_tokens) %></span> out
                        </div>
                      <% else %>
                        <span class="text-gray-400">N/A</span>
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm font-semibold text-gray-900">
                      $<%= sprintf("%.3f", log.cost_cents / 100.0) %>
                    </td>
                    <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-0">
                      <!-- Expandable prompt/response (could add modal here) -->
                      <button type="button" class="text-indigo-600 hover:text-indigo-900" 
                              onclick="toggleDetails('<%= log.id %>')">
                        View
                      </button>
                    </td>
                  </tr>
                  <!-- Expandable details row -->
                  <tr id="details-<%= log.id %>" class="hidden">
                    <td colspan="7" class="px-4 py-4 bg-gray-50">
                      <div class="space-y-3">
                        <% if log.prompt_text.present? %>
                          <div>
                            <h4 class="text-sm font-medium text-gray-900">Prompt:</h4>
                            <p class="mt-1 text-sm text-gray-700 bg-white p-3 rounded-md border">
                              <%= truncate(log.prompt_text, length: 500) %>
                            </p>
                          </div>
                        <% end %>
                        
                        <% if log.response_text.present? %>
                          <div>
                            <h4 class="text-sm font-medium text-gray-900">Response:</h4>
                            <div class="mt-1 text-sm text-gray-700 bg-white p-3 rounded-md border">
                              <%= truncate(log.response_text, length: 500).html_safe %>
                            </div>
                          </div>
                        <% end %>
                        
                        <% if log.metadata.present? %>
                          <div>
                            <h4 class="text-sm font-medium text-gray-900">Metadata:</h4>
                            <pre class="mt-1 text-xs text-gray-600 bg-white p-3 rounded-md border overflow-x-auto">
<%= JSON.pretty_generate(log.metadata) %>
                            </pre>
                          </div>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- Pagination -->
      <% if @total_pages > 1 %>
        <nav class="flex items-center justify-between border-t border-gray-200 px-4 sm:px-0 mt-6">
          <div class="-mt-px flex w-0 flex-1">
            <% if @page > 1 %>
              <%= link_to admin_cost_reports_user_path(@user, company_id: @target_company&.id, date_range: @date_range, page: @page - 1),
                  class: "inline-flex items-center border-t-2 border-transparent pr-1 pt-4 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700" do %>
                <svg class="mr-3 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a.75.75 0 01-.75.75H4.66l2.1 1.95a.75.75 0 11-1.02 1.1l-3.5-3.25a.75.75 0 010-1.1l3.5-3.25a.75.75 0 111.02 1.1L4.66 9.25H17.25A.75.75 0 0118 10z" clip-rule="evenodd" />
                </svg>
                Previous
              <% end %>
            <% end %>
          </div>
          <div class="hidden md:-mt-px md:flex">
            <span class="inline-flex items-center border-t-2 border-transparent px-4 pt-4 text-sm font-medium text-gray-500">
              Page <%= @page %> of <%= @total_pages %>
            </span>
          </div>
          <div class="-mt-px flex w-0 flex-1 justify-end">
            <% if @page < @total_pages %>
              <%= link_to admin_cost_reports_user_path(@user, company_id: @target_company&.id, date_range: @date_range, page: @page + 1),
                  class: "inline-flex items-center border-t-2 border-transparent pl-1 pt-4 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700" do %>
                Next
                <svg class="ml-3 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
                </svg>
              <% end %>
            <% end %>
          </div>
        </nav>
      <% end %>
    </div>
  </div>
</div>

<script>
  function toggleDetails(logId) {
    const detailsRow = document.getElementById('details-' + logId);
    if (detailsRow.classList.contains('hidden')) {
      detailsRow.classList.remove('hidden');
    } else {
      detailsRow.classList.add('hidden');
    }
  }
</script>
<div class="bg-white shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-lg leading-6 font-medium text-gray-900">AI Models Configuration</h3>
    <div class="mt-2 max-w-xl text-sm text-gray-500">
      <p>Configure which AI models to use for content and image generation across your organization.</p>
    </div>

    <!-- Company Selection (for default admin only) -->
    <% if current_company&.subdomain == "default" %>
      <%= form_with url: admin_ai_models_path, method: :get, local: true, class: "mb-5" do |company_form| %>
        <div>
          <label for="company_id" class="block text-sm font-medium text-gray-700">Company</label>
          <div class="mt-1">
            <%= company_form.select :company_id, 
                options_from_collection_for_select(@companies, :id, :name, @target_company&.id),
                { prompt: "Select a company..." },
                { 
                  class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md",
                  onchange: "this.form.submit();"
                } %>
          </div>
          <p class="mt-2 text-sm text-gray-500">Select a company to configure their AI model preferences.</p>
        </div>
      <% end %>
    <% end %>

    <%= form_with url: admin_ai_models_path, method: :patch, local: true, class: "mt-5" do |form| %>
      <%= form.fields_for :ai_models do |ai_form| %>
        <% if @target_company %>
          <%= ai_form.hidden_field :company_id, value: @target_company.id %>
        <% end %>
        <div class="space-y-6">

          <% if @target_company %>
            <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-blue-800">
                    Configuring for: <%= @target_company.name %>
                  </h3>
                  <div class="mt-2 text-sm text-blue-700">
                    <p>These settings will apply to all AI content and image generation for this company.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Generative Model Selection -->
            <div>
              <label for="ai_models_generative_model" class="block text-sm font-medium text-gray-700">
                Generative Model for Content Creation
              </label>
              <div class="mt-1">
                <%= ai_form.select :generative_model, 
                    options_for_select(@generative_models.map { |model| [model[:name], model[:id]] }, @current_settings[:generative_model]),
                    {},
                    { 
                      class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md",
                      id: "ai_models_generative_model"
                    } %>
              </div>
            
            <!-- Model descriptions -->
            <div class="mt-3 space-y-2">
              <% @generative_models.each do |model| %>
                <div class="text-sm text-gray-600 <% unless @current_settings[:generative_model] == model[:id] %>hidden<% end %>" 
                     data-model="<%= model[:id] %>">
                  <strong><%= model[:name] %>:</strong> <%= model[:description] %>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Image Model Selection -->
          <div>
            <label for="ai_models_image_model" class="block text-sm font-medium text-gray-700">
              Image Generation Model
            </label>
            <div class="mt-1">
              <%= ai_form.select :image_model,
                  options_for_select(@image_models.map { |model| [model[:name], model[:id]] }, @current_settings[:image_model]),
                  {},
                  { 
                    class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md",
                    id: "ai_models_image_model"
                  } %>
            </div>
            
            <!-- Model descriptions -->
            <div class="mt-3 space-y-2">
              <% @image_models.each do |model| %>
                <div class="text-sm text-gray-600 <% unless @current_settings[:image_model] == model[:id] %>hidden<% end %>" 
                     data-model="<%= model[:id] %>">
                  <strong><%= model[:name] %>:</strong> <%= model[:description] %>
                </div>
              <% end %>
            </div>
          </div>

            <!-- Submit Button -->
            <div class="pt-5">
              <div class="flex justify-end">
                <%= ai_form.submit "Update AI Model Settings", 
                    class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
              </div>
            </div>
        <% else %>
          <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-yellow-800">
                  Select Company
                </h3>
                <div class="mt-2 text-sm text-yellow-700">
                  <p>Please select a company above to configure their AI model settings.</p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<!-- Stimulus controller for dynamic model descriptions -->
<div data-controller="ai-model-selector">
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const generativeSelect = document.getElementById('ai_models_generative_model');
      const imageSelect = document.getElementById('ai_models_image_model');
      
      function updateDescriptions(selectElement, prefix) {
        const selectedValue = selectElement.value;
        const descriptions = document.querySelectorAll(`[data-model]`);
        
        descriptions.forEach(desc => {
          if (desc.closest('.space-y-2').previousElementSibling.querySelector('select') === selectElement) {
            if (desc.dataset.model === selectedValue) {
              desc.classList.remove('hidden');
            } else {
              desc.classList.add('hidden');
            }
          }
        });
      }
      
      if (generativeSelect) {
        generativeSelect.addEventListener('change', () => updateDescriptions(generativeSelect, 'generative'));
      }
      
      if (imageSelect) {
        imageSelect.addEventListener('change', () => updateDescriptions(imageSelect, 'image'));
      }
    });
  </script>
</div>